# Canonical mandatory tags — SINGLE SOURCE OF TRUTH.
#
# Consumed by:
#   - infra/scripts/deploy-direct.sh  (sources this file, builds the tag strings)
#   - backend/lambdas/shared/tags.js  (reads these as PROJECT_TAG / TEAM_TAG /
#     SQUAD / DEFAULT_OWNER / RESOURCE_EXPIRES / ENVIRONMENT_TAG from the Lambda
#     environment, which deploy-direct.sh populates from the values below)
#
# The SCP enforces these 6 tags at resource-creation time. Change a value here
# and re-run deploy-direct.sh — both planes pick it up.
TAG_PROJECT=sandboxagent
TAG_TEAM=sandboxagent
TAG_SQUAD=developer-experience
TAG_OWNER=francisco.lanuza@aplazo.mx
TAG_EXPIRES=2026-05-30
TAG_ENVIRONMENT=hackathon26
